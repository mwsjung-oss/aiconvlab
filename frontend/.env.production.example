# APS 프론트 — 운영 빌드(AWS Amplify 또는 로컬 `npm run build`)용 변수 예시
# 로컬: `cp .env.production.example .env.production` 후 값만 채워 사용 (`.env.production` 은 커밋 금지 권장)
#
# 브라우저에 노출되는 퍼블릭 설정만 저장합니다.
#
# 플레이스홀더 (문서 형식용):
#   VITE_API_BASE_URL=https://<AWS_EB_BACKEND_URL>
#   VITE_AWS_API_URL=https://<AWS_EB_BACKEND_URL>

VITE_APP_ENV=production
VITE_API_BASE_URL=https://REPLACE-WITH-YOUR-AWS-EB-API-HOST.invalid
VITE_AWS_API_URL=https://REPLACE-WITH-YOUR-AWS-EB-API-HOST.invalid
VITE_DEFAULT_EXECUTION_TARGET=aws
VITE_ENABLE_LAB_GPU=true
VITE_ENABLE_LLM_PROVIDER_SELECT=true
VITE_API_TIMEOUT_MS=20000
