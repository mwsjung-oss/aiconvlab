# Public Vite variables (브라우저 번들에 포함됩니다).

# Cloud(Render) APS Backend — 운영·CI 에서는 고정(https://ailab-backend.onrender.com).
# 로컬에서 Vite 프록시로 같은 PC 의 FastAPI 에 붙이려면 VITE_API_BASE_URL 을 비우고,
# 선택적으로 frontend/.env.development.local 에 `VITE_API_BASE_URL=` 만 둘 수 있습니다.
VITE_API_BASE_URL=https://ailab-backend.onrender.com

# AWS APS Backend 오리진 — 필수(비우면 APS 빌드 실패 및 런타임 차단).
# 실제 AWS 배포 URL 로 교체하세요. 초기 플레이스홀더는 반드시 실제 도메인으로 바꿉니다.
VITE_AWS_API_URL=https://your-aws-backend-domain.com



VITE_API_TIMEOUT_MS=20000
VITE_DEV_PORT=5174
VITE_LOCAL_API_URL=http://127.0.0.1:8000
