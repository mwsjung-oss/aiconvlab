# Public Vite variables (values are embedded in the browser bundle).

# Cloudflare Pages / static hosting: absolute API origin (no trailing slash).
# Leave empty for same-origin `/api` (Vite dev/preview proxy handles backend).
# 운영 Render(Blueprint: render.yaml) 기본: https://ailab-backend.onrender.com
# VITE_API_BASE_URL=https://ailab-backend.onrender.com

VITE_API_BASE_URL=

# Optional deploy label (defaults to Vite MODE).
# VITE_APP_ENV=production

VITE_API_TIMEOUT_MS=20000
VITE_DEV_PORT=5174

# Local FastAPI URL used as dev proxy default (local cookie mode).
VITE_LOCAL_API_URL=http://127.0.0.1:8000

# Remote lab API (browser cookie lab mode).
# Cloudflare Pages production build uses this value if localStorage override is empty.
# Use backend origin (or proxy root). `/api` suffix is optional.
# 예: VITE_LAB_API_URL=https://aiconlab.com
VITE_LAB_API_URL=

# Legacy name (backward compatibility). Prefer VITE_LAB_API_URL.
# VITE_DEV_PROXY_TARGET=http://your-lab-host:8000

# Cloud / AWS API base for cookie aws mode (empty => aws mode returns 503).
# VITE_AWS_API_URL=https://your-api.execute-api.example.com
VITE_AWS_API_URL=
