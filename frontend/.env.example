# Public Vite variables (브라우저 번들에 포함됩니다).

# Primary 운영: AWS EB 공개 HTTPS API — docs/aws-cutover-runbook.md
# 로컬에서 Vite 프록시만 쓸 때는 VITE_API_BASE_URL 을 비울 수 있습니다.
# 형식 참고만 (문자 그대로 쓰지 말 것):
#   VITE_API_BASE_URL=https://<AWS_EB_BACKEND_URL>
VITE_API_BASE_URL=https://REPLACE-WITH-YOUR-AWS-EB-API-HOST.invalid

VITE_AWS_API_URL=https://REPLACE-WITH-YOUR-AWS-EB-API-HOST.invalid

VITE_API_TIMEOUT_MS=20000
VITE_DEV_PORT=5174
VITE_LOCAL_API_URL=http://127.0.0.1:8000
