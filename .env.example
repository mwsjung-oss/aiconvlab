# Repository-root .env template used by the lightweight LLM gateway
# (backend/src/main.py + backend/src/services/llm_gateway.py).
#
# Usage:
#   1) cp .env.example .env       # Windows: Copy-Item .env.example .env
#   2) fill in real values; NEVER commit .env
#
# Note: .env, .env.save, .env.local are all git-ignored.

# Required
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides (defaults shown)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-flash-latest
# EMBEDDING_MODEL=text-embedding-3-small

# Optional RAG configuration
# VECTOR_DB_PATH=backend/data/vector_db
# VECTOR_DB_COLLECTION=default

# Optional CORS for the lightweight gateway (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional log level
# LOG_LEVEL=INFO
