# 연구실 서버(Tailscale 등)용 — 이 파일을 복사해 backend/.env 로 두고 값만 채웁니다.
#   cp .env.lab.example .env && nano .env

# --- 저장소 (대용량 디스크 권장) ---
AILAB_STORAGE_ROOT=/var/lib/ailab

# --- 보안 (반드시 변경) ---
# openssl rand -hex 32
JWT_SECRET=

MASTER_EMAIL=
MASTER_PASSWORD=

# --- 공개 URL (이메일 인증 링크에 사용) — 서버의 Tailscale IP 또는 고정 호스트 ---
# 예: http://100.70.20.91:8000
BACKEND_PUBLIC_URL=http://100.70.20.91:8000

# --- CORS: 노트북에서 Vite(localhost:5174)로 붙을 때 필수. 콤마 구분 ---
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# --- 이메일 (선택) ---
EMAIL_MODE=auto
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# --- 관리자 패널 (선택) ---
# ADMIN_PANEL_PASSWORD=
