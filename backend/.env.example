# 실험 데이터·모델·SQLite·작업 레지스트리를 둘 루트 (비우면 backend 폴더와 동일)
# 연구소 서버에서 대용량 디스크를 쓸 때 예: AILAB_STORAGE_ROOT=/srv/ailab-data
# AILAB_STORAGE_ROOT=
#
# --- Runtime label (optional; complements frontend VITE_APP_ENV for logs/feature flags) ---
# AILAB_ENV=local
# ENVIRONMENT=local
# Runtime abstraction defaults
# AILAB_DEFAULT_RUNTIME=local
# AILAB_ALLOWED_RUNTIMES=local,lab,cloud
#
# Provider toggles (safe by default: disabled)
# OPENAI_ENABLED=false
# GEMINI_ENABLED=false
# AWS_ENABLED=false
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# --- 연구실 Linux 서버(Tailscale) 배포: backend/.env.lab.example 참고 후 scripts/lab-server/ 실행 ---

# 마스터 계정 (최초 기동 시 DB에 없으면 자동 생성)
MASTER_EMAIL=your@email.com
MASTER_PASSWORD=change-this-password
# 기존 MASTER_EMAIL 계정의 비밀번호를 위 값으로 덮어씁니다. 1회 적용 후 반드시 제거하거나 0으로 두세요.
# MASTER_PASSWORD_RESYNC=1

# Director / Technical Lead — 서버 기동 시 해당 이메일 계정의 role을 갱신합니다(콤마·세미콜론 구분).
# 이 역할은 전 회원의 데이터(공유 워크스페이스)를 조회·학습·예측할 수 있고, /api/admin 도 사용할 수 있습니다.
# 동일 이메일이 두 목록에 있으면 TECHNICAL_LEAD_EMAILS가 나중에 적용됩니다. 마스터 계정 이메일은 넣지 마세요.
# DIRECTOR_EMAILS=director@example.com
# TECHNICAL_LEAD_EMAILS=lead@example.com

# JWT (운영에서는 긴 무작위 문자열로 변경)
JWT_SECRET=change-me-in-production-use-long-random-string

# Professor 옆 관리자 패널 초기 비밀번호 (미설정 시 secu9041, 이후 data/admin_panel.json 에 저장)
# ADMIN_PANEL_PASSWORD=secu9041

# 이메일 인증 링크에 쓰는 백엔드 공개 URL (외부에서 접근 가능한 주소로 설정)
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# CORS: 로컬 PC에서 Cursor+Vite(예: localhost:5174)로 개발하고 API는 이 서버를 쓸 때 필수.
# 콤마로 구분. 비어 있으면 http://localhost:5174,http://127.0.0.1:5174 만 허용.
# 연구실 서버에 배포 후에는 아래처럼 로컬 개발 오리진을 반드시 포함하세요.
# CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://your-frontend.example.com

# 이메일 발송 모드
# - auto (기본): SMTP_HOST, SMTP_USER, SMTP_PASSWORD, SMTP_FROM(또는 USER)가 모두 있으면 실제 발송, 아니면 콘솔에 링크 출력
# - smtp: 반드시 SMTP로 발송 (미설정 시 회원가입 시 오류)
# - console: 항상 콘솔만
EMAIL_MODE=auto

# --- 실제 메일 발송 (Gmail 예: Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=앱에서_발급한_16자리
# SMTP_FROM=your@gmail.com
# SMTP_TIMEOUT=30
# SMTP_USE_TLS=true
# 포트 465(SSL 직접): SMTP_PORT=465, SMTP_USE_SSL=true, SMTP_USE_TLS=false
# 연결 오류 시(Windows 등): SMTP_LOCAL_HOSTNAME=localhost

# --- AI 채팅 백엔드 (선택) ---
# OPENAI_API_KEY=   # provider/AI-chat 공용 키
# OPENAI_CHAT_MODEL=gpt-4o-mini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# Ollama OpenAI 호환 엔드포인트 (기본: 로컬)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2

# --- Jupyter Lab (브라우저 노트북, 선택) ---
# pip install jupyterlab 후 백엔드 .env 에 추가
# NOTEBOOK_ENABLED=1
# 동시 세션 상한 (기본 8)
# NOTEBOOK_MAX_SESSIONS=8
# 브라우저에 알려줄 호스트 (로컬: 127.0.0.1, LAN에서 접속 시 서버 IP)
# NOTEBOOK_ADVERTISE_HOST=127.0.0.1
# Jupyter 바인딩 (외부에서 접속 허용 시 0.0.0.0)
# NOTEBOOK_BIND=127.0.0.1
