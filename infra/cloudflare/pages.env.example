# (선택) 수동 복사용. 레포 내 frontend/.env.production 이 기본 빌드 기준이며,
# Cloudflare Pages 대시보드의 Environment Variables 로 덮어쓸 수 있습니다.

VITE_APP_ENV=production
VITE_API_BASE_URL=https://ailab-backend.onrender.com

# APS 정책상 필수. 비우면 빌드 실패( scripts/assert-vite-aws-env.mjs ).
VITE_AWS_API_URL=https://your-aws-backend-domain.com
