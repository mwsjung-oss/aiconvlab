# (선택) 수동 복사용. 실제로는 루트에 committed 된 frontend/.env.production 이 빌드 기준입니다.
# Cloudflare Pages 대시보드에 VITE_* 를 넣으면 그 값이 .env.production 을 덮어쓸 수 있으니, 충돌 시 대시보드에서 삭제하세요.

VITE_APP_ENV=production
VITE_API_BASE_URL=https://ailab-backend.onrender.com
VITE_AWS_API_URL=
VITE_LAB_API_URL=

# Legacy compatibility only; prefer VITE_LAB_API_URL
# VITE_DEV_PROXY_TARGET=

